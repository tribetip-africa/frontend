###############################################################################
# TribeTip frontend — initial local launch
# cp .env.local.example .env.local
# Keep platform + API on the same host (127.0.0.1 *or* localhost, not mixed).
# Mirror TRIBETIP_LAUNCH_MODE from tribetip/.env.
###############################################################################

NEXT_PUBLIC_TRIBETIP_PLATFORM_URL=http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001

# open | waitlist | coming_soon
NEXT_PUBLIC_LAUNCH_MODE=open

# Cookie auth (default on) — set to 0 only for legacy Bearer/localStorage mode
# NEXT_PUBLIC_AUTH_COOKIE=1

# Region launch flags (default: Kenya only)
# NEXT_PUBLIC_ENABLED_REGIONS=KE,NG

# Optional waitlist Google Sheets capture
# WAITLIST_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/....../exec
