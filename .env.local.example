# Development defaults (used when unset):
#   NEXT_PUBLIC_TRIBETIP_PLATFORM_URL=http://localhost:3000
#   NEXT_PUBLIC_API_URL=http://localhost:3001
#
# Production build defaults:
#   NEXT_PUBLIC_TRIBETIP_PLATFORM_URL=https://tribetip.africa
#   NEXT_PUBLIC_API_URL=https://api.tribetip.africa

NEXT_PUBLIC_TRIBETIP_PLATFORM_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Production: CSP is enforced. Development uses Content-Security-Policy-Report-Only.

## Region launch flags (must match API when overriding)
# Default: only Kenya (KE) is enabled.
# NEXT_PUBLIC_ENABLED_REGIONS=KE,NG
# Or toggle one market:
# NEXT_PUBLIC_REGION_NG_ENABLED=true

## Launch mode (public site gating)
# open         — normal sign-up and log in (default)
# waitlist     — public waitlist; /sign-up needs early-access invite; /sign-in stays open
# coming_soon  — no waitlist; /sign-up needs invite; /sign-in stays open
# NEXT_PUBLIC_LAUNCH_MODE=waitlist
# Match API: TRIBETIP_LAUNCH_MODE=waitlist
#
# Google Sheets webhook (server-only). Deploy the Apps Script below as a web app
# (Execute as: Me, Who has access: Anyone), then paste the deployment URL here:
# WAITLIST_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/....../exec
#
# Optional Search Console / Bing verification tokens (HTML meta tag method):
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-token
# NEXT_PUBLIC_BING_SITE_VERIFICATION=your-bing-token
#
# Optional IndexNow key for faster search-engine refresh after deploys:
# INDEXNOW_KEY=your-32-char-key
#
